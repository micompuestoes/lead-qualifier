# ─────────────────────────────────────────────
# Inmobia — Variables de entorno del BACKEND (FastAPI)
# Copia este archivo a .env y rellena los valores.
# NUNCA subas .env a git.
# ─────────────────────────────────────────────

# ── Anthropic (OBLIGATORIO) ───────────────────
ANTHROPIC_API_KEY=<tu-clave-de-anthropic>

# ── Autenticación Clerk (OBLIGATORIO en producción) ──
# URL del JWKS de tu instancia de Clerk. Sin ella, el backend corre en modo dev sin auth.
CLERK_JWKS_URL=https://tu-instancia.clerk.accounts.dev/.well-known/jwks.json

# ── Base de datos ─────────────────────────────
# Local: dejar vacío → usa SQLite automáticamente.
# Producción: PostgreSQL (Render/Railway inyectan esta variable).
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── CORS ──────────────────────────────────────
# Orígenes permitidos para el dashboard. localhost:3000 siempre está permitido.
# Usa DASHBOARD_URL (recomendado) o ALLOWED_ORIGINS (lista separada por comas).
DASHBOARD_URL=https://app.inmobia.es
# ALLOWED_ORIGINS=https://app.inmobia.es,https://www.inmobia.es

# ── Panel de administración ───────────────────
# Clave secreta para los endpoints /admin/*. Debe coincidir en backend y dashboard.
# OJO: también se usa para derivar la clave de cifrado (Fernet) de las contraseñas IMAP,
# así que si la cambias dejarás de poder descifrar las bandejas ya conectadas.
ADMIN_SECRET_KEY=genera-una-clave-larga-y-aleatoria
# user_id de Clerk del dueño del SaaS (único que puede ver el panel admin).
SUPER_ADMIN_USER_ID=user_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe (pagos) ────────────────────────────
STRIPE_SECRET_KEY=<tu-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<tu-stripe-webhook-secret>
# IDs de precio de cada plan (los creas en el dashboard de Stripe)
STRIPE_PRICE_PRO=<price-id-del-plan-pro>
STRIPE_PRICE_AGENCIA=<price-id-del-plan-agencia>

# ── Email (recomendado: Resend/Postmark/SendGrid con dominio verificado) ──
# IMPORTANTE para entregabilidad: el dominio de FROM_EMAIL necesita SPF, DKIM y DMARC en su DNS.
FROM_EMAIL=contacto@inmobia.es
FROM_NAME=Inmobia
# Opción A: SendGrid
# SENDGRID_API_KEY=<tu-sendgrid-api-key>
# Opción B: SMTP
# SMTP_HOST=smtp.tudominio.com
# SMTP_PORT=587
# SMTP_USER=contacto@inmobia.es
# SMTP_PASSWORD=xxxxxxxxxxxx

# ── Monitorización de errores (opcional) ──────
# SENTRY_DSN=<tu-sentry-dsn>
# SENTRY_ENV=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

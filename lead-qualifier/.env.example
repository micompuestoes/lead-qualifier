# ─────────────────────────────────────────────
# Lead Qualifier — Variables de entorno
# Copia este archivo a .env y rellena los valores
# NUNCA subas .env a git
# ─────────────────────────────────────────────

# ── Anthropic (obligatorio en local y producción) ──
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Base de datos ─────────────────────────────────
# Local: dejar vacío → usa SQLite automáticamente
# Producción (Railway): Railway inyecta esta variable al añadir el plugin PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── CORS para el dashboard ────────────────────────
# Local: no hace falta (localhost:3000 siempre permitido)
# Producción: poner la URL del frontend en Railway
# FRONTEND_URL=https://dashboard-production.up.railway.app

# ── Email (opcional) ──────────────────────────────

# Opción A: SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# FROM_EMAIL=hola@tuempresa.com
# FROM_NAME=Tu Empresa

# Opción B: SMTP (Gmail, Outlook...)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tucuenta@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# FROM_EMAIL=tucuenta@gmail.com
# FROM_NAME=Tu Nombre

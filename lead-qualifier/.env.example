# ─────────────────────────────────────────────
# Inmuebia — Variables de entorno del BACKEND (FastAPI)
# Copia este archivo a .env y rellena los valores.
# NUNCA subas .env a git.
# ─────────────────────────────────────────────

# ── Anthropic (OBLIGATORIO) ───────────────────
ANTHROPIC_API_KEY=<tu-clave-de-anthropic>

# ── Autenticación Clerk (OBLIGATORIO en producción) ──
# URL del JWKS de tu instancia de Clerk. Sin ella el backend NO arranca,
# salvo que actives DEV_MODE=1 (solo desarrollo local).
CLERK_JWKS_URL=https://tu-instancia.clerk.accounts.dev/.well-known/jwks.json
# Issuer esperado en los JWT. Si no se define, se deriva de CLERK_JWKS_URL
# (la URL de la instancia sin "/.well-known/jwks.json"). Solo hace falta
# definirlo si usas un dominio propio de Clerk cuyo issuer no coincida.
# CLERK_ISSUER=https://tu-instancia.clerk.accounts.dev

# ── Modo desarrollo (NUNCA en producción) ─────
# DEV_MODE=1 permite arrancar sin Clerk (todas las peticiones actúan como
# 'dev-tenant') y cifrar con una clave insegura de desarrollo.
# DEV_MODE=1

# ── Base de datos ─────────────────────────────
# Local: dejar vacío → usa SQLite automáticamente.
# Producción: PostgreSQL (Render/Railway inyectan esta variable).
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── CORS ──────────────────────────────────────
# Orígenes permitidos para el dashboard. localhost:3000 siempre está permitido.
# Usa DASHBOARD_URL (recomendado) o ALLOWED_ORIGINS (lista separada por comas).
DASHBOARD_URL=https://app.inmuebia.es
# ALLOWED_ORIGINS=https://app.inmuebia.es,https://www.inmuebia.es

# ── Panel de administración ───────────────────
# Clave secreta para los endpoints /admin/*. Debe coincidir en backend y dashboard.
# OJO: también se usa para derivar la clave de cifrado (Fernet) de las contraseñas IMAP,
# así que si la cambias dejarás de poder descifrar las bandejas ya conectadas.
ADMIN_SECRET_KEY=genera-una-clave-larga-y-aleatoria
# user_id de Clerk del dueño del SaaS (único que puede ver el panel admin).
SUPER_ADMIN_USER_ID=user_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Cifrado de contraseñas IMAP (recomendado en producción) ──
# Clave Fernet dedicada para cifrar las contraseñas IMAP en la BD.
# Si no se define, se deriva de ADMIN_SECRET_KEY (compatibilidad). Definirla aquí
# te permite rotar ADMIN_SECRET_KEY sin perder acceso a las bandejas ya conectadas.
# Genera una con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEY=<clave-fernet-de-44-caracteres>

# ── Stripe (pagos) ────────────────────────────
STRIPE_SECRET_KEY=<tu-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<tu-stripe-webhook-secret>
# IDs de precio de cada plan (los creas en el dashboard de Stripe)
STRIPE_PRICE_PRO=<price-id-del-plan-pro>
# IMPORTANTE: Agencia se factura POR ASIENTO (por agente). Crea el precio en
# Stripe como recurrente "por unidad" (per-seat); el backend pasa la cantidad =
# nº de agentes y la sincroniza al añadir/quitar miembros del equipo.
STRIPE_PRICE_AGENCIA=<price-id-por-asiento-del-plan-agencia>

# ── Email (recomendado: Resend/Postmark/SendGrid con dominio verificado) ──
# IMPORTANTE para entregabilidad: el dominio de FROM_EMAIL necesita SPF, DKIM y DMARC en su DNS.
FROM_EMAIL=contacto@inmuebia.es
FROM_NAME=Inmuebia
# Opción A: SendGrid
# SENDGRID_API_KEY=<tu-sendgrid-api-key>
# Opción B: SMTP
# SMTP_HOST=smtp.tudominio.com
# SMTP_PORT=587
# SMTP_USER=contacto@inmuebia.es
# SMTP_PASSWORD=xxxxxxxxxxxx

# ── WhatsApp (avisos de leads calientes al agente) ──
# API oficial de WhatsApp Cloud (Meta). Si no se define, los avisos por WhatsApp
# quedan desactivados (el resto del producto funciona igual).
# WHATSAPP_TOKEN=<token-de-la-app-de-whatsapp-business>
# WHATSAPP_PHONE_ID=<phone-number-id-del-remitente>
# Plantilla (debe estar APROBADA en Meta) con 4 variables en el cuerpo, en orden:
#   {{1}} clasificación+score   {{2}} nombre del lead   {{3}} teléfono   {{4}} enlace al panel
# Ejemplo de cuerpo a crear en Meta (categoría UTILITY, idioma es):
#   "🔥 Nuevo lead {{1}}. Cliente: {{2}} ({{3}}). Entra a responder: {{4}}"
# WHATSAPP_TEMPLATE_HOT_LEAD=hot_lead_alert
# WHATSAPP_TEMPLATE_LANG=es
# WHATSAPP_API_VERSION=v21.0

# ── Monitorización de errores (opcional) ──────
# SENTRY_DSN=<tu-sentry-dsn>
# SENTRY_ENV=production
# SENTRY_TRACES_SAMPLE_RATE=0.1

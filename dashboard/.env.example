# ─────────────────────────────────────────────
# Inmonia — Variables de entorno del DASHBOARD (Next.js)
# En Vercel: Settings → Environment Variables.
# Las NEXT_PUBLIC_* se exponen al navegador; el resto solo al servidor.
# ─────────────────────────────────────────────

# ── API del backend (OBLIGATORIO en producción) ──
# Sin esta variable, en local usa el proxy a http://localhost:8000.
NEXT_PUBLIC_API_URL=https://api.inmonia.es

# ── Clerk (OBLIGATORIO) ───────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=<tu-clerk-publishable-key>
CLERK_SECRET_KEY=<tu-clerk-secret-key>
# Usar NUESTRAS páginas de login/registro (no la página alojada de Clerk)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Panel de administración (server-only) ─────
# Debe coincidir EXACTAMENTE con la del backend.
ADMIN_SECRET_KEY=la-misma-clave-que-el-backend
# user_id de Clerk del dueño (debe coincidir con el del backend).
SUPER_ADMIN_USER_ID=user_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Monitorización de errores (opcional) ──────
# NEXT_PUBLIC_SENTRY_DSN=<tu-sentry-dsn>   # errores del navegador
# SENTRY_DSN=<tu-sentry-dsn>               # errores del servidor Next
# NEXT_PUBLIC_SENTRY_ENV=production
